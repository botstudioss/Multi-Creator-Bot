# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_token_here
BOT_TOKEN=your_token_here
POLLING_CHANNEL_ID=your_channel_id_here
ADMIN_IDS=your_admin_ids_here

# Database Configuration (Required for 24/7 operation)
DATABASE_URL=postgresql://user:password@localhost:5432/pollmasterbot

# MCP Server Configuration (From mcp-servers.json)
# Optional: Can also be loaded from mcp-servers.json
MCP_SERVERS_CONFIG={"mcpServers":{"justrunmy.app":{"url":"https://justrunmy.app/api/mcp","headers":{"X-User-Identity":"..."}}}}

# Optional Environment Variables
NODE_ENV=production
LOG_LEVEL=info
